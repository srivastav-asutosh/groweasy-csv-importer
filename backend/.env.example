# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# LLM provider selection: openai | gemini | anthropic | mock
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Provide the key for whichever provider you selected above
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Extraction tuning
BATCH_SIZE=20
BATCH_CONCURRENCY=3
MAX_RETRIES=3
MAX_UPLOAD_SIZE_MB=15
